{
  "name": "@avenzo/api",
  "version": "1.0.0",
  "description": "Avenzo REST API — Express + Prisma",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/jobs/worker.js",
    "dev:worker": "nodemon src/jobs/worker.js",
    "smoke": "node scripts/smoke-test.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "lint": "node --check src/server.js && node --check src/app.js && node --check src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate",
    "deploy:db": "prisma migrate deploy && prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^6.19.3",
    "razorpay": "^2.9.6",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "setupFiles": ["./tests/setup.js"],
    "testTimeout": 15000
  }
}
