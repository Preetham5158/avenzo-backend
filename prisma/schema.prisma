generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////////
// ENUMS (UNCHANGED)
//////////////////////////////////////////////////////

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum UserRole {
  USER
  RESTAURANT_OWNER
  EMPLOYEE
  ADMIN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum FoodType {
  VEG
  NON_VEG
}

enum RestaurantFoodType {
  PURE_VEG
  NON_VEG
  BOTH
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}

enum PaymentStatus {
  PAYMENT_NOT_REQUIRED
  PAYMENT_PENDING
  PAID
  PAYMENT_FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum NotificationStatus {
  LOGGED
  SKIPPED
  FAILED
}

enum NotificationChannel {
  LOG
  EMAIL
  SMS
  WHATSAPP
}

enum OtpPurpose {
  CUSTOMER_LOGIN
  RESTAURANT_LOGIN
  SIGNUP_VERIFY
  ORDER_CONFIRMATION
  PASSWORD_RESET
}

enum OtpChannel {
  EMAIL
  SMS
  LOG
}

enum OrderAttemptStatus {
  ACCEPTED
  REJECTED
}

enum AuditAction {
  RESTAURANT_CREATED
  RESTAURANT_UPDATED
  SUBSCRIPTION_UPDATED
  STAFF_ADDED
  STAFF_REMOVED
  ORDER_STATUS_UPDATED
  ORDER_ATTEMPT_REJECTED
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  phoneVerifiedAt DateTime?
  emailVerifiedAt DateTime?

  role      UserRole @default(USER)

  ownedRestaurants Restaurant[] @relation("RestaurantOwner")
  orders Order[] @relation("CustomerOrders")
  otpChallenges OtpChallenge[]

  staffRestaurantId String?
  staffRestaurant   Restaurant? @relation("RestaurantStaff", fields: [staffRestaurantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffRestaurantId])
}

model RestaurantLead {
  id String @id @default(uuid())

  restaurantName String
  contactName String
  phone String
  email String
  location String?
  restaurantType String?
  approxDailyOrders String?
  message String?
  internalNote String?
  status LeadStatus @default(NEW)
  viewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([viewedAt])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// RESTAURANT
//////////////////////////////////////////////////////

model Restaurant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  address   String?
  locality  String?
  pickupNote String?
  foodType RestaurantFoodType @default(BOTH)

  ownerId   String
  owner     User     @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  staff     User[]   @relation("RestaurantStaff")

  menus     Menu[]
  orders    Order[]
  categories Category[]
  ratings   OrderRating[]

  isActive  Boolean  @default(true)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  subscriptionEndsAt DateTime?

  // order numbering
  orderCounter Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

//////////////////////////////////////////////////////
// CATEGORY (NEW — CONTROLLED LOOKUP)
//////////////////////////////////////////////////////

model Category {
  id        String   @id @default(uuid())
  name      String

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  menus     Menu[]

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  // prevent duplicate categories per restaurant
  @@unique([restaurantId, name])
  @@index([restaurantId])
}

//////////////////////////////////////////////////////
// MENU
//////////////////////////////////////////////////////

model Menu {
  id    String @id @default(uuid())
  name  String
  pricePaise Int

  description String?
  imageUrl    String?
  foodType    FoodType @default(VEG)

  isAvailable Boolean @default(true)
  isActive    Boolean @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  // 🔥 FIXED: category is now controlled
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([categoryId])
}

//////////////////////////////////////////////////////
// ORDER
//////////////////////////////////////////////////////

model Order {
  id           String      @id @default(uuid())

  // per restaurant order number
  orderNumber  Int

  totalPricePaise Int
  paymentStatus PaymentStatus @default(PAYMENT_NOT_REQUIRED)
  status       OrderStatus @default(PENDING)
  pickupCode   String
  trackingToken String @unique

  phone        String
  tableNumber  String?
  sessionId    String

  customerId   String?
  customer     User? @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: SetNull)
  readyAt      DateTime?

  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  items        OrderItem[]
  notificationLogs NotificationLog[]
  rating       OrderRating?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([createdAt])
  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([phone])
}

//////////////////////////////////////////////////////
// ORDER ITEM
//////////////////////////////////////////////////////

model OrderItem {
  id       String @id @default(uuid())

  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuId   String
  menu     Menu   @relation(fields: [menuId], references: [id])

  quantity Int

  priceAtOrderPaise Int
  nameAtOrder  String

  createdAt DateTime @default(now())

  @@index([orderId])
}

model NotificationLog {
  id String @id @default(uuid())

  userId String?
  orderId String?
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  recipientPhone String?
  recipientEmail String?
  recipientMasked String?
  purpose String?
  channel NotificationChannel
  status NotificationStatus
  error String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model OtpChallenge {
  id String @id @default(uuid())

  userId String?
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  email String?
  phone String?
  purpose OtpPurpose
  channel OtpChannel
  otpHash String
  expiresAt DateTime
  consumedAt DateTime?
  attempts Int @default(0)
  maxAttempts Int @default(5)
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([phone])
  @@index([purpose])
  @@index([expiresAt])
}

model OrderAttempt {
  id String @id @default(uuid())

  restaurantId String?
  phone String?
  deviceId String?
  ipHash String?
  status OrderAttemptStatus
  reason String?

  createdAt DateTime @default(now())

  @@index([restaurantId])
  @@index([phone])
  @@index([deviceId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// ORDER RATING
//////////////////////////////////////////////////////

model OrderRating {
  id           String     @id @default(uuid())
  orderId      String     @unique
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId   String?
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  rating       Int        // 1–5
  comment      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@index([customerId])
}

model BlockedPhone {
  id String @id @default(uuid())
  phone String @unique
  reason String?
  createdAt DateTime @default(now())
}

model BlockedDevice {
  id String @id @default(uuid())
  deviceId String @unique
  reason String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(uuid())

  actorUserId String?
  action AuditAction
  restaurantId String?
  orderId String?
  targetUserId String?
  metadata Json?
  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([restaurantId])
  @@index([orderId])
  @@index([createdAt])
}
