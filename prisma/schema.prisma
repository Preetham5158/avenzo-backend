generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////////
// ENUMS (UNCHANGED)
//////////////////////////////////////////////////////

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum UserRole {
  USER
  RESTAURANT_OWNER
  EMPLOYEE
  ADMIN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum FoodType {
  VEG
  NON_VEG
}

enum RestaurantFoodType {
  PURE_VEG
  NON_VEG
  BOTH
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?

  role      UserRole @default(USER)

  ownedRestaurants Restaurant[] @relation("RestaurantOwner")

  staffRestaurantId String?
  staffRestaurant   Restaurant? @relation("RestaurantStaff", fields: [staffRestaurantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffRestaurantId])
}

//////////////////////////////////////////////////////
// RESTAURANT
//////////////////////////////////////////////////////

model Restaurant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  address   String?
  locality  String?
  pickupNote String?
  foodType RestaurantFoodType @default(BOTH)

  ownerId   String
  owner     User     @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  staff     User[]   @relation("RestaurantStaff")

  menus     Menu[]
  orders    Order[]
  categories Category[]

  isActive  Boolean  @default(true)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  subscriptionEndsAt DateTime?

  // order numbering
  orderCounter Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

//////////////////////////////////////////////////////
// CATEGORY (NEW — CONTROLLED LOOKUP)
//////////////////////////////////////////////////////

model Category {
  id        String   @id @default(uuid())
  name      String

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  menus     Menu[]

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  // prevent duplicate categories per restaurant
  @@unique([restaurantId, name])
  @@index([restaurantId])
}

//////////////////////////////////////////////////////
// MENU
//////////////////////////////////////////////////////

model Menu {
  id    String @id @default(uuid())
  name  String
  pricePaise Int

  description String?
  imageUrl    String?
  foodType    FoodType @default(VEG)

  isAvailable Boolean @default(true)
  isActive    Boolean @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  // 🔥 FIXED: category is now controlled
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([categoryId])
}

//////////////////////////////////////////////////////
// ORDER
//////////////////////////////////////////////////////

model Order {
  id           String      @id @default(uuid())

  // per restaurant order number
  orderNumber  Int

  totalPricePaise Int
  status       OrderStatus @default(PENDING)
  pickupCode   String
  trackingToken String @unique

  phone        String?
  sessionId    String

  customerId   String?
  readyAt      DateTime?

  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  items        OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([createdAt])
  @@index([status])
}

//////////////////////////////////////////////////////
// ORDER ITEM
//////////////////////////////////////////////////////

model OrderItem {
  id       String @id @default(uuid())

  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuId   String
  menu     Menu   @relation(fields: [menuId], references: [id])

  quantity Int

  priceAtOrderPaise Int
  nameAtOrder  String

  createdAt DateTime @default(now())

  @@index([orderId])
}
