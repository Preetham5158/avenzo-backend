DATABASE_URL="postgresql://user:password@host:5432/database"
DIRECT_URL="postgresql://user:password@host:5432/database"
JWT_SECRET="replace-with-a-long-random-secret"
BASE_URL="http://localhost:5000"
ENABLE_BOOTSTRAP_SCHEMA=false

# OTP / 2FA
# OTP_MODE=log   → prints code to server console. Development only; blocked in production.
# OTP_MODE=email → sends OTP via Resend. Requires EMAIL_PROVIDER, RESEND_API_KEY, FROM_EMAIL.
OTP_MODE=log
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# All authenticated users (customer and restaurant/admin) require email OTP.
# Set AUTH_REQUIRE_CUSTOMER_2FA=false locally only when OTP_MODE=log for faster dev iteration.
AUTH_REQUIRE_RESTAURANT_2FA=true
AUTH_REQUIRE_CUSTOMER_2FA=true

# Notifications
# NOTIFICATION_MODE=log   → logs intent to console and NotificationLog table only.
# NOTIFICATION_MODE=email → sends order emails via Resend. Requires email config below.
NOTIFICATION_MODE=log

# Email provider — Resend
# Required when OTP_MODE=email or NOTIFICATION_MODE=email.
# Domain must be verified in Resend dashboard before enabling in production.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=Avenzo <no-reply@avenzo.app>
SUPPORT_EMAIL=support@avenzo.app

# SMS (future — India DLT registration required before enabling)
SMS_PROVIDER=
