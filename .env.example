# ============================================================
# Avenzo Backend — Environment Variables Reference
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_BASE_URL=http://localhost:5000

# ── Database (Supabase / PostgreSQL) ─────────────────────────
# DATABASE_URL  : pooled connection (pgBouncer) for queries
# DIRECT_URL    : direct connection for migrations
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/database"

# ── Auth ─────────────────────────────────────────────────────
# Use a cryptographically random string of at least 64 chars.
# Production: generate with `openssl rand -hex 64`
JWT_SECRET="replace-with-a-long-random-secret-minimum-32-chars"
# Optional — required for future refresh token implementation
# JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"

# Deprecated alias (kept for backward compat, prefer APP_BASE_URL)
BASE_URL=http://localhost:5000

# ── Payments (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret from Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_CURRENCY=INR

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Redis ────────────────────────────────────────────────────
# Required in production for distributed rate limiting and caching.
# Local dev: redis://localhost:6379
# Upstash:   rediss://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# ── OTP / 2FA ────────────────────────────────────────────────
# OTP_MODE=log   → prints code to server console. Development only.
#                  Automatically BLOCKED in NODE_ENV=production.
# OTP_MODE=email → sends OTP via Resend. Requires email config.
OTP_MODE=log
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Set both to true in production for full 2FA security.
AUTH_REQUIRE_RESTAURANT_2FA=false
AUTH_REQUIRE_CUSTOMER_2FA=false

# ── Notifications ────────────────────────────────────────────
# NOTIFICATION_MODE=log   → logs to console + NotificationLog table only.
# NOTIFICATION_MODE=email → sends order emails via Resend.
NOTIFICATION_MODE=log

# ── Email (Resend) ───────────────────────────────────────────
# Required when OTP_MODE=email or NOTIFICATION_MODE=email.
# Domain must be verified in Resend dashboard first.
EMAIL_PROVIDER=
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcard in production.
# Example: https://avenzo.app,https://admin.avenzo.app
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# ── Observability (optional but recommended) ─────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_DSN=

# ── Bootstrap (migration shim — disable once fully migrated) ──
ENABLE_BOOTSTRAP_SCHEMA=false

# ── Seed passwords (used only by scripts/seed.js, never in production) ──
# SEED_ADMIN_PASSWORD=your_secure_admin_password
# SEED_OWNER_PASSWORD=your_secure_owner_password
# SEED_STAFF_PASSWORD=your_secure_staff_password

# ── SMS (future — India DLT registration required) ───────────
SMS_PROVIDER=
