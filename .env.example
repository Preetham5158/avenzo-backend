DATABASE_URL="postgresql://user:password@host:5432/database"
DIRECT_URL="postgresql://user:password@host:5432/database"
JWT_SECRET="replace-with-a-long-random-secret"
BASE_URL="http://localhost:5000"
ENABLE_BOOTSTRAP_SCHEMA=false

# OTP / 2FA
# OTP_MODE=log   → prints code to server console. Development only; blocked in NODE_ENV=production.
# OTP_MODE=email → sends OTP via Resend. Requires EMAIL_PROVIDER, RESEND_API_KEY, FROM_EMAIL.
# Production (Render): OTP_MODE=email
OTP_MODE=log
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Set both to true in production. Keep false locally for faster dev iteration with OTP_MODE=log.
# Production (Render): AUTH_REQUIRE_RESTAURANT_2FA=true, AUTH_REQUIRE_CUSTOMER_2FA=true
AUTH_REQUIRE_RESTAURANT_2FA=false
AUTH_REQUIRE_CUSTOMER_2FA=false

# Notifications
# NOTIFICATION_MODE=log   → logs intent to console and NotificationLog table only.
# NOTIFICATION_MODE=email → sends order emails via Resend. Requires email config below.
# Production (Render): NOTIFICATION_MODE=email
NOTIFICATION_MODE=log

# Email provider — Resend
# Required when OTP_MODE=email or NOTIFICATION_MODE=email.
# Domain must be verified in Resend dashboard before enabling in production.
# Production (Render): EMAIL_PROVIDER=resend
EMAIL_PROVIDER=
RESEND_API_KEY=
FROM_EMAIL=
SUPPORT_EMAIL=

# SMS (future — India DLT registration required before enabling)
SMS_PROVIDER=
